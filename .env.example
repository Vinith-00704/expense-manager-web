# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

FLASK_ENV=production
PORT=5000

# Database (Railway MySQL / PlanetScale / etc.)
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=finance_manager

# Security Keys (change these to random strong strings in production!)
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
PASSWORD_PEPPER=change-me-to-a-strong-random-pepper
